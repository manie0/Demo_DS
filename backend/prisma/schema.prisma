generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GlobalTankConfig {
  id                    Int      @id
  siteName              String
  sampleRateSeconds     Int
  alertThresholdPercent Float
  calibrationOffset     Float
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
}
