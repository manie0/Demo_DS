generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CalibrationConfig {
  id             Int      @id
  sensorOffsetCm Float    @default(0)
  scaleFactor    Float    @default(1)
  minValidCm     Float    @default(0)
  maxValidCm     Float    @default(300)
  updatedAt      DateTime @updatedAt
}

model Reading {
  id           Int      @id @default(autoincrement())
  rawCm        Float
  calibratedCm Float
  isValid      Boolean
  createdAt    DateTime @default(now())
}
